{
  "project_mode": "demo",
  "project_root": "../../..",
  "insightface_repo_root": "",
  "identity_queue_csv": "outputs/offline_runs/demo/events/identity_resolution_queue.csv",
  "dataset_profile_path": "insightface_demo_assets/runtime/config/dataset_profile.new_dataset_demo.yaml",
  "known_face_manifest_csv": "insightface_demo_assets/known_face_manifest.csv",
  "known_face_gallery_root": "insightface_demo_assets/known_faces",
  "known_face_embeddings_csv": "insightface_demo_assets/runtime/known_face_embeddings_template.csv",
  "resolved_events_csv": "insightface_demo_assets/runtime/resolved_events_template.csv",
  "unknown_profiles_csv": "insightface_demo_assets/runtime/unknown_profiles_template.csv",
  "association_policy_config": "insightface_demo_assets/runtime/config/association_policy.new_dataset_demo.yaml",
  "camera_transition_map_config": "insightface_demo_assets/runtime/config/camera_transition_map.new_dataset_demo.yaml",
  "scene_calibration_config": "insightface_demo_assets/runtime/config/manual_scene_calibration.new_dataset_demo.yaml",
  "insightface_runtime": {
    "python_runtime_available": true,
    "model_pack_available": true,
    "recommended_model_name": "buffalo_l",
    "recommended_model_root": "",
    "recommended_model_cache_dir": "",
    "provider": "CPUExecutionProvider"
  },
  "matching": {
    "known_match_threshold": 0.75,
    "fallback_to_body_feature": true,
    "face_quality_policy": "use_best_head_crop_then_body_crop_from_identity_queue"
  },
  "unknown_handling": {
    "mode": "assign_unknown_global_id_when_no_known_match",
    "seed_prefix": "UNK",
    "start_index": 1
  }
}
